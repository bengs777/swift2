# Required for production (Vercel)
NEXTAUTH_URL=https://swift.example.com
NEXTAUTH_SECRET=replace_with_a_secure_random_value
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
TURSO_DATABASE_URL=libsql://<your-turso-instance>
TURSO_AUTH_TOKEN=your_turso_auth_token

# Optional local-only override. Local dev falls back to file:./prisma/dev.db.
# DATABASE_URL=file:./dev.db

# App URL used by absolute links and redirects
NEXT_PUBLIC_APP_URL=https://swift.example.com

# Official developer treasury account
DEV_OWNER_EMAIL=ibnualmugni1933@gmail.com

# OpenRouter AI setup
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MAX_TOKENS=3000

# Optional but recommended
VERCEL_ACCESS_TOKEN=
