# Required for production (Vercel)
NEXTAUTH_URL=https://swift.example.com
NEXTAUTH_SECRET=replace_with_a_secure_random_value
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
TURSO_DATABASE_URL=libsql://<your-turso-instance>
TURSO_AUTH_TOKEN=your_turso_auth_token

# Optional local-only override. Local dev falls back to file:./prisma/dev.db.
# DATABASE_URL=file:./dev.db

# App URL used by absolute links and redirects
NEXT_PUBLIC_APP_URL=https://swift.example.com

# Official developer treasury account
DEV_OWNER_EMAIL=ibnualmugni1933@gmail.com

# OpenRouter-compatible AI setup
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=
AI_MAX_OUTPUT_TOKENS=3000
OPENAI_API_KEY=your_openrouter_api_key
OPENAI_API_URL=https://openrouter.ai/api/v1
OPENAI_DEFAULT_MODEL=qwen/qwen3-coder:free
OPENAI_MODELS=qwen/qwen3-coder:free,tencent/hy3-preview:free,qwen/qwen3.6-plus-preview:free
OPENAI_FALLBACK_MODEL=qwen/qwen3-coder:free

# Optional but recommended
VERCEL_ACCESS_TOKEN=

# AI / other keys (only if used in production)
# AGENT_ROUTER_TOKEN=
